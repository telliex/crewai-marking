# IMPORTANT: put comments on their OWN line. pydantic-settings does NOT strip
# inline "value  # comment" — the "# comment" becomes part of the value (this
# silently corrupts keys, the From address, and the compliance postal address).

# --- External services ---
# people search + email unlock (bulk_match spends credits)
APOLLO_API_KEY=
# sending
RESEND_API_KEY=
# CrewAI angle writer
ANTHROPIC_API_KEY=
# angle writer web research
SERPER_API_KEY=

# --- Database (Postgres in prod; SQLite works for local dev) ---
DATABASE_URL=postgresql+psycopg://outreach:outreach@localhost:5432/outreach

# --- Sender identity / compliance (a campaign may override any of these) ---
# use a SUBDOMAIN to protect main-domain reputation
OUTREACH_FROM=steven@mail.yourdomain.com
OUTREACH_FROM_NAME=Steven
# a monitored inbox
OUTREACH_REPLY_TO=steven@yourdomain.com
OUTREACH_SENDER_NAME=Steven Wu
OUTREACH_COMPANY=Awkns
# REQUIRED for real sends (legal); blank blocks sending
OUTREACH_POSTAL_ADDRESS=
OUTREACH_UNSUBSCRIBE_MAILTO=
# HMAC secret for unsubscribe tokens
OUTREACH_UNSUBSCRIBE_SECRET=change-me

# --- Web ---
# used to build unsubscribe links
APP_BASE_URL=http://localhost:8000
# HTTP-Basic password for the admin dashboard
ADMIN_PASSWORD=
# (follow-up) svix secret to verify Resend webhooks
RESEND_WEBHOOK_SECRET=

# --- Writer ---
CREW_MODEL=anthropic/claude-sonnet-4-5
